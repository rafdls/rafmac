#!/bin/sh
# Install oh-my-zsh. Runs once. .zshrc (managed by chezmoi) sources it.
set -eu

{{ if .install_omzsh -}}
if [ -d "$HOME/.oh-my-zsh" ]; then
  echo "==> oh-my-zsh already installed, skipping."
  exit 0
fi

echo "==> Installing oh-my-zsh..."
# --unattended: don't change the shell or launch zsh, and don't clobber .zshrc
# (chezmoi manages .zshrc).
RUNZSH=no KEEP_ZSHRC=yes sh -c \
  "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended

echo "==> oh-my-zsh installed."
{{- else -}}
echo "==> install_omzsh is false, skipping oh-my-zsh."
{{- end }}
