# UI
# Matches Neovim's tokyonight so ANSI colours line up in :terminal, tmux and CLIs.
# Follows the macOS system appearance automatically. No `background` override so
# each variant's own background applies. Opacity is global (see below), so light
# mode stays slightly translucent.
theme = dark:TokyoNight Night,light:TokyoNightDay-readable
font-size = 16
font-family = "JetBrains Mono Nerd Font"
font-thicken = true
font-thicken-strength = 1
adjust-cell-height = 1
background-opacity = 1
background-blur=16
macos-titlebar-style = transparent
window-padding-x = 8
window-padding-y = 8


# Fix reisizing pane with tmux
macos-option-as-alt = left
keybind = alt+arrow_left=unbind
keybind = alt+arrow_right=unbind

# Quality of life
mouse-hide-while-typing = true

# scrollback-limit in bytes, roughly 125,000 lines
scrollback-limit = 10000000
